{
  "name": "codex-gateway-hub",
  "private": false,
  "version": "0.1.0",
  "description": "OpenAI-compatible API gateway for Codex/Responses with multi-provider routing, model mapping, vision fallback, runtime switching, and usage analytics.",
  "homepage": "https://github.com/q1820926174-cpu/codex-gateway-hub",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/q1820926174-cpu/codex-gateway-hub.git"
  },
  "bugs": {
    "url": "https://github.com/q1820926174-cpu/codex-gateway-hub/issues"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20.9.0"
  },
  "keywords": [
    "openai-compatible",
    "responses-api",
    "chat-completions",
    "codex",
    "llm-gateway",
    "multi-provider",
    "model-routing",
    "vision-fallback",
    "nextjs",
    "prisma"
  ],
  "scripts": {
    "predev": "npm run prisma:generate",
    "prebuild": "npm run prisma:generate",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "db:init": "node --env-file-if-exists=.env scripts/init-db.mjs",
    "db:migrate:from-sqlite": "node --env-file-if-exists=.env scripts/migrate-sqlite-to-db.mjs",
    "prisma:generate": "node --env-file-if-exists=.env scripts/prisma-generate.mjs",
    "prisma:migrate": "npm run prisma:generate && npm run db:init",
    "prisma:reset": "npm run prisma:generate && node --env-file-if-exists=.env scripts/init-db.mjs --reset",
    "bench:codex-prompts": "node scripts/benchmark-codex-prompts.mjs"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.22",
    "clsx": "^2.1.1",
    "echarts": "^6.0.0",
    "echarts-for-react": "^3.0.6",
    "framer-motion": "^12.36.0",
    "js-tiktoken": "^1.0.21",
    "lucide-react": "^0.577.0",
    "next": "^16.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.71.2",
    "react-json-view-lite": "^2.5.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0",
    "tdesign-react": "^1.16.6",
    "zod": "^4.1.12",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@types/node": "^22.18.6",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "prisma": "^6.19.2",
    "typescript": "^5.9.3"
  }
}
