# 数据库类型 / Database provider: sqlite / mysql / postgresql
DATABASE_PROVIDER="sqlite"
# 数据库连接串（SQLite 默认本地文件） / Database URL (SQLite defaults to local file)
DATABASE_URL="file:./dev.db"
# 控制台入口暗号（留空表示不启用） / Console entry secret (empty means disabled)
CONSOLE_ENTRY_SECRET=""
# 控制台入口 Cookie 的 Secure 策略（auto/true/false，默认 auto） / Secure policy for entry cookie (auto/true/false, default auto)
CONSOLE_ENTRY_COOKIE_SECURE="auto"
ANTHROPIC_VERSION="2023-06-01"
OPENAI_FILE_STORAGE_DIR="./data/openai-files"
OPENAI_FILE_UPLOAD_MAX_BYTES="20971520"
OPENAI_FILE_DATA_URL_MAX_BYTES="20971520"

# 网关 Key 缓存 TTL（毫秒，0 关闭） / Gateway key cache TTL in ms (0 to disable)
GATEWAY_KEY_CACHE_TTL_MS="1500"
# 网关 Key 缓存条目上限 / Gateway key cache max entries
GATEWAY_KEY_CACHE_MAX="2048"
# 流式请求超时（毫秒，0 表示不超时，默认 10 分钟） / Stream request timeout in ms (0 disables timeout, default 10 min)
GATEWAY_STREAM_TIMEOUT_MS="600000"

# Docker 国内加速模式（0 关闭，1 开启） / Docker CN acceleration mode (0 off, 1 on)
DOCKER_ACCELERATE_CN="0"
# 常规 npm 源 / Default npm registry
NPM_REGISTRY="https://registry.npmjs.org/"
# 国内加速 npm 源（开启加速模式时使用） / CN npm registry (used when acceleration mode is on)
NPM_REGISTRY_CN="https://registry.npmmirror.com/"
# 可选代理（留空表示不走代理） / Optional proxy settings (empty means disabled)
HTTP_PROXY=""
HTTPS_PROXY=""
NO_PROXY="localhost,127.0.0.1"
