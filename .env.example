# 数据库类型 / Database provider: sqlite / mysql / postgresql
DATABASE_PROVIDER="sqlite"
# 数据库连接串（SQLite 默认本地文件） / Database URL (SQLite defaults to local file)
DATABASE_URL="file:./dev.db"
# 控制台入口暗号（留空表示不启用） / Console entry secret (empty means disabled)
CONSOLE_ENTRY_SECRET=""

# 网关 Key 缓存 TTL（毫秒，0 关闭） / Gateway key cache TTL in ms (0 to disable)
GATEWAY_KEY_CACHE_TTL_MS="1500"
# 网关 Key 缓存条目上限 / Gateway key cache max entries
GATEWAY_KEY_CACHE_MAX="2048"

# MySQL 配置（用于 docker-compose.mysql.yml） / MySQL settings (for docker-compose.mysql.yml)
# 数据库名 / Database name
MYSQL_DATABASE="codex_gateway"
# 普通账号用户名 / Application username
MYSQL_USER="codex"
# 普通账号密码 / Application password
MYSQL_PASSWORD="codex"
# root 管理员密码 / Root password
MYSQL_ROOT_PASSWORD="rootpass"

# PostgreSQL 配置（用于 docker-compose.postgres.yml） / PostgreSQL settings (for docker-compose.postgres.yml)
# 数据库名 / Database name
POSTGRES_DB="codex_gateway"
# 用户名 / Username
POSTGRES_USER="codex"
# 密码 / Password
POSTGRES_PASSWORD="codex"
