# 数据库类型 / Database provider: sqlite / mysql / postgresql
DATABASE_PROVIDER="sqlite"
# 数据库连接串（SQLite 默认本地文件） / Database URL (SQLite defaults to local file)
DATABASE_URL="file:./dev.db"
# 控制台入口暗号（留空表示不启用） / Console entry secret (empty means disabled)
CONSOLE_ENTRY_SECRET=""
# 控制台入口 Cookie 的 Secure 策略（auto/true/false，默认 auto） / Secure policy for entry cookie (auto/true/false, default auto)
CONSOLE_ENTRY_COOKIE_SECURE="auto"
ANTHROPIC_VERSION="2023-06-01"

# 网关 Key 缓存 TTL（毫秒，0 关闭） / Gateway key cache TTL in ms (0 to disable)
GATEWAY_KEY_CACHE_TTL_MS="1500"
# 网关 Key 缓存条目上限 / Gateway key cache max entries
GATEWAY_KEY_CACHE_MAX="2048"
